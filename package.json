  "bugs": {
    "url": "https://github.com/renalyng17/My_Porfolio/issues"
  },
  "homepage": "https://github.com/renalyng17/My_Porfolio#readme",
  "devDependencies": {
    "concurrently": "^7.6.0"
  }
}